{
  "mcpServers": {
    "postgresql-mcp": {
      "command": "npx",
      "args": ["-y", "@henkey/postgres-mcp-server"],
      "timeout": 60000
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "timeout": 60000
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"],
      "timeout": 60000
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"],
      "timeout": 60000
    },
    "supabase": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp",
      "timeout": 60000
    }
  }
}
